@{
    ViewBag.Title = "Xét Học Bổng Tự Động";
}

<style>
    /* Card hiệu ứng kính mờ (Glassmorphism) cực chất */
    .cool-card {
        background: rgba(22, 27, 34, 0.7);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(110, 118, 129, 0.3);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
        border-radius: 16px;
    }

    .cool-header {
        background: linear-gradient(135deg, #1f6feb 0%, #8957e5 100%);
        border-radius: 15px 15px 0 0 !important;
        padding: 20px;
    }

    .form-control {
        background-color: #0d1117 !important;
        border: 1px solid #30363d !important;
        color: #f0f6fc !important;
        border-radius: 8px;
        padding: 12px;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            border-color: #58a6ff !important;
            box-shadow: 0 0 0 3px rgba(88, 166, 255, 0.3) !important;
        }

    .btn-cyber {
        background: linear-gradient(135deg, #238636 0%, #2ea043 100%);
        border: none;
        color: white;
        font-weight: 600;
        padding: 12px;
        border-radius: 8px;
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .btn-cyber:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(46, 160, 67, 0.4);
        }

    .alert-custom {
        background: rgba(56, 139, 253, 0.1);
        border: 1px solid rgba(56, 139, 253, 0.3);
        color: #58a6ff;
        border-radius: 10px;
    }
</style>

<div class="container" style="max-width: 600px;">
    <div class="card cool-card">
        <div class="card-header cool-header text-white text-center">
            <h4 class="mb-0"><i class="fa-solid fa-user-graduate me-2"></i>Hệ Thống Xét Duyệt Học Bổng</h4>
        </div>
        <div class="card-body p-4">

            @using (Html.BeginForm("Index", "Home", FormMethod.Post))
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold text-light">Điểm trung bình tích lũy (GPA - Hệ 4.0)</label>
                    <input type="number" step="0.1" min="0" max="4" name="gpa" value="@ViewBag.Gpa" class="form-control" placeholder="Nhập điểm ví dụ: 3.5" required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold text-light">Điểm rèn luyện (Hệ 100)</label>
                    <input type="number" min="0" max="100" name="trainingPoint" value="@ViewBag.TrainingPoint" class="form-control" placeholder="Nhập điểm ví dụ: 85" required />
                </div>

                <button type="submit" class="btn btn-cyber w-100 btn-lg">
                    <i class="fa-solid fa-magnifying-glass me-2"></i>Kiểm Tra Kết Quả
                </button>
            }

            @if (ViewBag.Result != null)
            {
                <div class="mt-4">
                    <div class="alert alert-custom p-3 text-center" role="alert">
                        <span class="d-block text-muted small uppercase fw-bold mb-1">Kết quả phân tích hệ thống</span>
                        <h5 class="alert-heading mb-0 fw-bold" style="color: #ffffff !important;">@ViewBag.Result</h5>
                    </div>
                </div>
            }

        </div>
    </div>
</div>