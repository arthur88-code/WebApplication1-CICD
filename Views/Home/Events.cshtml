@{ ViewBag.Title = "Đăng Ký Sự Kiện"; }
<div class="container" style="max-width: 600px;">
    <div class="card cool-card bg-black">
        <div class="card-header cool-header text-white text-center">
            <h4 class="mb-0"><i class="fa-solid fa-calendar-days me-2"></i>Đăng Ký Vé Sự Kiện CNTT</h4>
        </div>
        <div class="card-body p-4">
            @using (Html.BeginForm("Events", "Home", FormMethod.Post))
            {
                <div class="mb-3">
                    <label class="form-label text-light">Tuổi của bạn (Từ 15 - 60):</label>
                    <input type="number" name="age" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label text-light">Hạng vé:</label>
                    <select name="ticketType" class="form-control">
                        <option value="STANDARD">STANDARD - 200,000 VNĐ</option>
                        <option value="VIP">VIP - 500,000 VNĐ</option>
                    </select>
                </div>
                <div class="mb-4">
                    <label class="form-label text-light">Mã giảm giá (Nếu có):</label>
                    <input type="text" name="promoCode" class="form-control" placeholder="STUDENT hoặc GROUP4" />
                </div>
                <button type="submit" class="btn btn-cyber w-100 btn-lg btn-primary">Xác Nhận Đăng Ký</button>
            }
            @if (ViewBag.Result != null)
            {
                <div class="mt-4"><div class="alert alert-custom p-3 text-center text-white">@ViewBag.Result</div></div>
            }
        </div>
    </div>
</div>